#!/usr/bin/env bash
#
# An extended vim command as a wrapper, not a X11 Vim.
#

set -euo pipefail

export XDG_CONFIG_HOME=${XDG_CONFIG_HOME:-~/.config}

has () {
  type "$1" &>/dev/null
}

if (( $# )); then
  exec vim "$@"
fi

if [[ -z ${VIM-=:} ]]; then
  exec vim
fi

set -- vim

if command vim --version | grep -q +clientserver; then
  set -- "$@" --servername VIM
fi

if has dtach; then
  if has tput; then
    tput smcup || true
  fi

  dtach -A "$XDG_CONFIG_HOME/vim/.dtach.sock" -r winch "$@"

  if has tput; then
    tput rmcup || true
  fi
else
  exec "$@"
fi
